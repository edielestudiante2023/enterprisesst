#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development
# CI_ENVIRONMENT = production

# Cache path (directorio temporal para cache de la app)
cache.storePath = '/tmp/enterprisesst_cache'

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost/enterprisesst/public/'

#--------------------------------------------------------------------
# DATABASE — Conexion principal
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = empresas_sst
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

#--------------------------------------------------------------------
# DATABASE — Conexion readonly (Chat Otto — portal cliente)
#--------------------------------------------------------------------

readonly.hostname = localhost
readonly.username = empresas_readonly
readonly.password =
readonly.database = empresas_sst
readonly.port     = 3306
readonly.encrypt  = false

#--------------------------------------------------------------------
# SENDGRID — Email transaccional
#--------------------------------------------------------------------

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=notificacion.cycloidtalent@cycloidtalent.com
SENDGRID_FROM_NAME="Enterprise SST"

#--------------------------------------------------------------------
# OPENAI — Generacion de documentos e IA
#--------------------------------------------------------------------

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OTTO_MODEL=gpt-4o-mini

#--------------------------------------------------------------------
# API Key para acceso programatico (ext-api)
#--------------------------------------------------------------------

APP_API_KEY=
